# =============================================================================
# BIM — Terraform Variables
# =============================================================================
# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit secrets.

network = "testnet"

# After first `terraform apply`, copy the api_domain output here:
# api_domain = "bimxxxxxxxx-bim-api.functions.fnc.fr-par.scw.cloud"

# ---------- Database ----------
db_password = ""

# ---------- BIM addresses ----------
bim_treasury_address     = ""
bim_treasury_private_key = ""
# bim_avnu_address = ""

# ---------- Secrets ----------

# AVNU paymaster API key — https://portal.avnu.fi
# avnu_api_key = ""

# Apibara DNA token — https://www.apibara.com
# dna_token = ""

# Backend claimer account (auto-claim forward swaps)
# claimer_private_key = ""
# claimer_address = ""

# ---------- Alerting (optional) ----------
# Set enable_alerting = true and fill in Slack credentials to enable balance alerts.
# enable_alerting = true
# alerting_slack_bot_token = "xoxb-..."
# alerting_slack_channel = "#bim-alerts"
# alerting_balance_cron = "0 8 * * *"
# alerting_avnu_threshold_strk = 15
# alerting_treasury_threshold_strk = 200
