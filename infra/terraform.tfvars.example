# =============================================================================
# BIM — Terraform Variables
# =============================================================================
# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit secrets.

network = "mainnet"

# ------------------------------------------------------------------------------
# Server
# ------------------------------------------------------------------------------
api_domain = "app.bitcoinismoney.app"
api_log_level = "info"
indexer_log_level = "info"

# ------------------------------------------------------------------------------
# WebAuthn
# ------------------------------------------------------------------------------
webauthn_authenticator_attachment = ""

# ------------------------------------------------------------------------------
# Database (single admin user)
# ------------------------------------------------------------------------------
db_user = ""
db_password = ""

# ------------------------------------------------------------------------------
# Fees
# ------------------------------------------------------------------------------
bim_treasury_private_key = ""
bim_treasury_address = ""

# ------------------------------------------------------------------------------
# Claimer (same as bim treasury)
# ------------------------------------------------------------------------------
claimer_private_key = ""
claimer_address     = ""

# ------------------------------------------------------------------------------
# AVNU — API key (https://portal.avnu.fi) and full sponsor-activity URL used
# to monitor remaining sponsor credits.
# Testnet: https://sepolia.api.avnu.fi/paymaster/v1/sponsor-activity
# Mainnet: https://starknet.api.avnu.fi/paymaster/v1/sponsor-activity
# ------------------------------------------------------------------------------
avnu_api_key              = ""
avnu_sponsor_activity_url = "https://starknet.api.avnu.fi/paymaster/v1/sponsor-activity"

# ------------------------------------------------------------------------------
# Apibara DNA token — https://www.apibara.com
# ------------------------------------------------------------------------------
dna_token = ""

# ------------------------------------------------------------------------------
# Cron (alerting / reporting)
# every day - 8h : "0 8 * * *"
# every 2 minutes : "*/2 * * * *"
# ------------------------------------------------------------------------------
cron_secret              = "..."
alerting_slack_bot_token = "xoxb-..."

# ------------------------------------------------------------------------------
# Alerting (optional - Slack notifications on #alerting)
# ------------------------------------------------------------------------------
enable_alerting                       = true
alerting_balance_cron                 = "0 8 * * *"
alerting_avnu_threshold_strk          = 15
alerting_treasury_threshold_strk      = 100
alerting_treasury_threshold_wbtc_sats = 10000

# ------------------------------------------------------------------------------
# Reporting (optional - Slack notifications on #reporting)
# ------------------------------------------------------------------------------
enable_reporting        = false
activity_reporting_cron = "0 8 * * 1"
