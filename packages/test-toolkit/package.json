{
  "name": "@bim/test-toolkit",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Test helpers for the BIM monorepo (WebAuthn fakes, crypto fixtures).",
  "license": "GPL-3.0-or-later",
  "author": "yannicklacaute@bitcoinismoney.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bitcoin-is-money/bim.git",
    "directory": "packages/test-toolkit"
  },
  "bugs": {
    "url": "https://github.com/bitcoin-is-money/bim/issues"
  },
  "homepage": "https://github.com/bitcoin-is-money/bim#readme",
  "keywords": [
    "bim",
    "testing",
    "webauthn",
    "fixtures"
  ],
  "exports": {
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js"
    },
    "./crypto": {
      "types": "./dist/crypto/index.d.ts",
      "import": "./dist/crypto/index.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc --watch",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.8.0",
    "@simplewebauthn/server": "^13.3.0"
  }
}
