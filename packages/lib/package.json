{
  "name": "@bim/lib",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Shared utilities for the BIM monorepo (auth, encoding, logger, url).",
  "license": "GPL-3.0-or-later",
  "author": "yannicklacaute@bitcoinismoney.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bitcoin-is-money/bim.git",
    "directory": "packages/lib"
  },
  "bugs": {
    "url": "https://github.com/bitcoin-is-money/bim/issues"
  },
  "homepage": "https://github.com/bitcoin-is-money/bim#readme",
  "keywords": [
    "bim",
    "utilities",
    "encoding",
    "logger"
  ],
  "exports": {
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js"
    },
    "./encoding": {
      "types": "./dist/encoding/index.d.ts",
      "import": "./dist/encoding/index.js"
    },
    "./logger": {
      "types": "./dist/logger/index.d.ts",
      "import": "./dist/logger/index.js"
    },
    "./token": {
      "types": "./dist/token/index.d.ts",
      "import": "./dist/token/index.js"
    },
    "./url": {
      "types": "./dist/url/index.d.ts",
      "import": "./dist/url/index.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc --watch",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@stablelib/base64": "^2.0.1",
    "@stablelib/hex": "^2.0.1",
    "pino": "^10.0.0",
    "pino-pretty": "^13.0.0"
  }
}
