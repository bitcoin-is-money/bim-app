{
  "name": "@bim/atomiq",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Atomiq SDK adapter for BIM — Lightning / Bitcoin / Starknet swap integration.",
  "license": "GPL-3.0-or-later",
  "author": "yannicklacaute@bitcoinismoney.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bitcoin-is-money/bim.git",
    "directory": "packages/atomiq"
  },
  "bugs": {
    "url": "https://github.com/bitcoin-is-money/bim/issues"
  },
  "homepage": "https://github.com/bitcoin-is-money/bim#readme",
