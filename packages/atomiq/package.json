{
  "name": "@bim/atomiq",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Atomiq SDK adapter for BIM — Lightning / Bitcoin / Starknet swap integration.",
  "license": "GPL-3.0-or-later",
  "author": "yannicklacaute@bitcoinismoney.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bitcoin-is-money/bim-app.git",
    "directory": "packages/atomiq"
  },
  "bugs": {
    "url": "https://github.com/bitcoin-is-money/bim-app/issues"
  },
  "homepage": "https://github.com/bitcoin-is-money/bim-app#readme",
  "keywords": [
    "bim",
    "atomiq",
    "lightning",
    "bitcoin",
    "starknet",
    "swap"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "clean:all": "pnpm run clean && rm -rf node_modules",
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc --watch",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "@bim/atomiq-storage-postgres": "workspace:*",
    "@bim/domain": "workspace:*",
    "@bim/lib": "workspace:*",
    "pino": "^10.3.1"
  },
  "peerDependencies": {
    "@atomiqlabs/chain-starknet": "^8.2.2",
    "@atomiqlabs/sdk": "^8.0.0",
    "pg": "^8.0.0",
    "starknet": "^9.0.0"
  }
}
