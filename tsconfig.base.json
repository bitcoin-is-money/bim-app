{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "baseUrl": ".",
    "paths": {
      "@bim/lib/*": ["packages/lib/src/*"],
      "@bim/test-toolkit/*": ["packages/test-toolkit/src/*"],
      "@bim/db": ["packages/db/src/index.ts"],
      "@bim/domain/*": ["packages/domain/src/*"]
    }
  }
}
