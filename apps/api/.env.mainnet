# ==============================================================================
# BIM API - Mainnet Configuration
# ==============================================================================
# Default configuration for Starknet Mainnet (committed to git).
# Secrets go in .env.mainnet.secret (gitignored).
#
# Loaded by loadEnv('mainnet') — .env.mainnet.secret first, then this file.
#   - Dev server:    NETWORK=mainnet npm run dev -w @bim/api

# ------------------------------------------------------------------------------
# Server
# ------------------------------------------------------------------------------
NODE_ENV=production
LOG_LEVEL=info

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------
DATABASE_USER=bim_user
DATABASE_PASSWORD=bim_password
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_NAME=bim
DATABASE_URL="postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}"

# ------------------------------------------------------------------------------
# Starknet Network - Mainnet
# ------------------------------------------------------------------------------
STARKNET_NETWORK=mainnet

# Default: free Cartridge RPC (no API key needed, sufficient for local dev).
# For higher rate limits, use a paid provider (Alchemy, Infura, Blast).
STARKNET_RPC_URL=https://api.cartridge.gg/x/starknet/mainnet

# Account class hash — BIM Argent 0.5.0 (WebAuthn-enabled wallet contract).
# Same class hash as Sepolia (declared on both networks).
ACCOUNT_CLASS_HASH=0x04bc5b0950521985d3f8db954fc6ae3832122c6ee4cd770efdbf87437699ce48

# WBTC token contract address on Starknet Mainnet.
WBTC_TOKEN_ADDRESS=0x03fe2b97c1fd336e750087d68b9b867997fd64a2661ff3ca5a7c771641e8e7ac

# ------------------------------------------------------------------------------
# AVNU Paymaster - Gasless Transactions (SNIP-29 JSON-RPC)
# ------------------------------------------------------------------------------
# Paymaster endpoint (JSON-RPC, NOT the swap/DEX API at api.avnu.fi).
AVNU_API_URL=https://starknet.paymaster.avnu.fi

# API key for sponsored (gasfree) transactions.
# Set your key in .env.mainnet.secret (gitignored):
#   AVNU_API_KEY=your-key-here

# ------------------------------------------------------------------------------
# Atomiq SDK — Cross-chain swap provider
# ------------------------------------------------------------------------------
ATOMIQ_STORAGE_PATH=/tmp/bim/atomiq/mainnet
ATOMIQ_AUTO_CREATE_STORAGE=true

# LP node URL. Optional on mainnet (SDK default is correct).
#ATOMIQ_INTERMEDIARY_URL=https://node3.gethopa.com:34100

# Which token from the SDK's Starknet registry to use for swaps.
ATOMIQ_SWAP_TOKEN=WBTC

# ------------------------------------------------------------------------------
# Fees
# ------------------------------------------------------------------------------
# OLD FEE_TREASURY_ADDRESS=0x027367ddd36d7efc4694e1af5742f8d26626369c07abf15d136ff422b9a40fa0
FEE_TREASURY_ADDRESS=0x06c53f8ce155e02e587ca5ebee057857ce237e406bb370e019e9d937f71be07b

# ------------------------------------------------------------------------------
# WebAuthn Configuration
# ------------------------------------------------------------------------------
# Defaults (localhost) work for local dev — override in .env.mainnet.secret for production.
#WEBAUTHN_RP_ID=localhost
#WEBAUTHN_RP_NAME=BIM
WEBAUTHN_ORIGIN=http://localhost:8080
WEBAUTHN_AUTHENTICATOR_ATTACHMENT=platform
