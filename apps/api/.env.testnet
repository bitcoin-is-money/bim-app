# ==============================================================================
# BIM API - Testnet (Sepolia) Configuration
# ==============================================================================
# Default configuration for Sepolia testnet (committed to git).
# Secrets go in .env.testnet.secret (gitignored).
#
# Loaded by loadEnv('testnet') — .env.testnet.secret first, then this file.
#   - Testnet tests: npm run test:testnet -w @bim/api
#   - Dev server:    NETWORK=testnet npm run start:dev

# ------------------------------------------------------------------------------
# Server
# ------------------------------------------------------------------------------
NODE_ENV=production
LOG_LEVEL=debug

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------
# For tests: automatically set by TestContainers (overrides this value).
# For dev server: configure with your own PostgreSQL instance.
DATABASE_USER=bim_user
DATABASE_PASSWORD=bim_password
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=bim
DATABASE_URL="postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}"
DATABASE_SSL=require

# ------------------------------------------------------------------------------
# Starknet Network - Sepolia Testnet
# ------------------------------------------------------------------------------
STARKNET_NETWORK=testnet

# Default: free Cartridge RPC (no API key needed, sufficient for testing).
# For higher rate limits, use a paid provider (Alchemy, Infura, Blast).
STARKNET_RPC_URL=https://api.cartridge.gg/x/starknet/sepolia

# Optional: Alchemy (recommended for production)
#STARKNET_API_KEY=your_rpc_provider_api_key
#STARKNET_RPC_URL=https://starknet-sepolia.g.alchemy.com/starknet/version/rpc/v0_7/${STARKNET_API_KEY}

# Account class hash — BIM Argent 0.5.0 (WebAuthn-enabled wallet contract).
# Must be declared on Sepolia before use.
ACCOUNT_CLASS_HASH=0x04bc5b0950521985d3f8db954fc6ae3832122c6ee4cd770efdbf87437699ce48

# WBTC token contract address on Starknet Sepolia.
WBTC_TOKEN_ADDRESS=0x00452bd5c0512a61df7c7be8cfea5e4f893cb40e126bdc40aee6054db955129e

# ------------------------------------------------------------------------------
# AVNU Paymaster - Gasless Transactions (SNIP-29 JSON-RPC)
# ------------------------------------------------------------------------------
# Paymaster endpoint (JSON-RPC, NOT the swap/DEX API at api.avnu.fi).
AVNU_API_URL=https://sepolia.paymaster.avnu.fi

# API key for sponsored (gasfree) transactions.
# Required for account deployment (fresh accounts have 0 balance).
# Get one at https://portal.avnu.fi
# Set your key in .env.testnet.secret (gitignored):
#   AVNU_API_KEY=your-key-here

# ------------------------------------------------------------------------------
# Atomiq SDK — Cross-chain swap provider
# ------------------------------------------------------------------------------
ATOMIQ_STORAGE_PATH=/tmp/bim/atomiq/testnet
ATOMIQ_AUTO_CREATE_STORAGE=true

# LP node URL. Required on testnet: the SDK default (:24100) is a Solana-only node.
# The Starknet-capable LP runs on :8443.
ATOMIQ_INTERMEDIARY_URL=https://node3.gethopa.com:8443

# Which token from the SDK's Starknet registry to use for swaps.
# On testnet the LP only supports _TESTNET_WBTC_VESU, not WBTC.
# Available: ETH, STRK, WBTC, TBTC, USDC, USDT, _TESTNET_WBTC_VESU
ATOMIQ_SWAP_TOKEN=_TESTNET_WBTC_VESU

# ------------------------------------------------------------------------------
# Fees
# ------------------------------------------------------------------------------
# bim account, username=bim_testnet
FEE_TREASURY_ADDRESS=0x03dab31e6ed493eb4823779210148cce3897f7574960153459179791234dab72

# ------------------------------------------------------------------------------
# WebAuthn Configuration
# ------------------------------------------------------------------------------
# Defaults (localhost) work for testing — only change for production.
#WEBAUTHN_RP_ID=localhost
#WEBAUTHN_RP_NAME=BIM
WEBAUTHN_ORIGIN=https://localhost:8443
WEBAUTHN_AUTHENTICATOR_ATTACHMENT=platform
