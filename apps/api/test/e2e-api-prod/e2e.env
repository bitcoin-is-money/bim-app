# ==============================================================================
# BIM API - E2E API Production Tests
# ==============================================================================
# Config for E2E tests that hit the real production API via HTTP.
# Loaded by global-setup.ts ALONGSIDE config/mainnet.env (network constants).
#
# Only contains values that differ from the mainnet runtime defaults —
# notably the WebAuthn domain (prod-specific).
#
# Run: npm run test:e2e-api-prod -w @bim/api

STARKNET_RPC_URL=https://api.cartridge.gg/x/starknet/mainnet
WBTC_TOKEN_ADDRESS=0x03fe2b97c1fd336e750087d68b9b867997fd64a2661ff3ca5a7c771641e8e7ac
BIM_TREASURY_ADDRESS=0x05e5c078d66f03f5bd3b60c7a7a23b1b039c4d0d9a2a3e59d2532f54102e5218

# ------------------------------------------------------------------------------
# WebAuthn — MUST match the production server's config exactly.
# WEBAUTHN_ORIGIN doubles as the base URL for E2E HTTP calls.
# ------------------------------------------------------------------------------
WEBAUTHN_RP_ID=app.bitcoinismoney.app
WEBAUTHN_ORIGIN=https://app.bitcoinismoney.app

# ------------------------------------------------------------------------------
# Monitoring
# ------------------------------------------------------------------------------
# Slack bot token is read from apps/cli/.secrets.json (not an env var).
MONITORING_SLACK_CHANNEL="#e2e-tests"
