# ==============================================================================
# BIM API - Testnet (Sepolia) Blockchain Configuration
# ==============================================================================
# Network-specific constants: RPC endpoints, contract addresses, class hashes.
# Committed to git. No secrets, no infra-dependent values.
#
# Infra-dependent values (WEBAUTHN_*, DATABASE_URL, etc.) are injected by
# Terraform in production, or set in .env.local for local development.

# ------------------------------------------------------------------------------
# Starknet Network
# ------------------------------------------------------------------------------
STARKNET_NETWORK=testnet
STARKNET_RPC_URL=https://api.cartridge.gg/x/starknet/sepolia
ACCOUNT_CLASS_HASH=0x04bc5b0950521985d3f8db954fc6ae3832122c6ee4cd770efdbf87437699ce48
WBTC_TOKEN_ADDRESS=0x00452bd5c0512a61df7c7be8cfea5e4f893cb40e126bdc40aee6054db955129e

# ------------------------------------------------------------------------------
# AVNU Paymaster (SNIP-29 JSON-RPC endpoint, NOT the swap/DEX API)
# ------------------------------------------------------------------------------
AVNU_API_URL=https://sepolia.paymaster.avnu.fi
AVNU_SPONSOR_ACTIVITY_URL=https://sepolia.api.avnu.fi/paymaster/v1/sponsor-activity

# ------------------------------------------------------------------------------
# Atomiq SDK - Cross-chain swap provider
# ------------------------------------------------------------------------------
# LP node URL: required on testnet (SDK default :24100 is Solana-only, Starknet LP on :8443).
ATOMIQ_INTERMEDIARY_URL=https://node3.gethopa.com:8443
# On testnet the LP only supports _TESTNET_WBTC_VESU, not WBTC.
ATOMIQ_SWAP_TOKEN=_TESTNET_WBTC_VESU
