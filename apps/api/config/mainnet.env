# ==============================================================================
# BIM API - Mainnet Blockchain Configuration
# ==============================================================================
# Network-specific constants: RPC endpoints, contract addresses, class hashes.
# Committed to git. No secrets, no infra-dependent values.
#
# Infra-dependent values (WEBAUTHN_*, DATABASE_URL, etc.) are injected by
# Terraform in production, or set in .env.local for local development.

# ------------------------------------------------------------------------------
# Starknet Network
# ------------------------------------------------------------------------------
STARKNET_NETWORK=mainnet
STARKNET_RPC_URL=https://api.cartridge.gg/x/starknet/mainnet
ACCOUNT_CLASS_HASH=0x04bc5b0950521985d3f8db954fc6ae3832122c6ee4cd770efdbf87437699ce48
WBTC_TOKEN_ADDRESS=0x03fe2b97c1fd336e750087d68b9b867997fd64a2661ff3ca5a7c771641e8e7ac

# ------------------------------------------------------------------------------
# AVNU Paymaster (SNIP-29 JSON-RPC endpoint, NOT the swap/DEX API)
# ------------------------------------------------------------------------------
AVNU_API_URL=https://starknet.paymaster.avnu.fi
AVNU_SPONSOR_ACTIVITY_URL=https://starknet.api.avnu.fi/paymaster/v1/sponsor-activity

# ------------------------------------------------------------------------------
# Atomiq SDK - Cross-chain swap provider
# ------------------------------------------------------------------------------
# LP node URL: optional on mainnet (SDK default is correct).
#ATOMIQ_INTERMEDIARY_URL=https://node3.gethopa.com:34100
ATOMIQ_SWAP_TOKEN=WBTC
