{
  "name": "@bim/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist public/app",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --watch --noEmit",
    "dev": "NETWORK=testnet tsx watch src/main.ts",
    "dev:mainnet": "NETWORK=mainnet tsx watch src/main.ts",
    "build": "npm run typecheck && node esbuild.prod.js",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "test:testnet": "vitest run --config vitest.config.testnet.ts",
    "test:all": "npm run test && npm run test:integration",
    "copy:front": "rm -rf public/app && cp -r ../front/dist/frontend/browser/browser public/app"
  },
  "dependencies": {
    "@atomiqlabs/chain-starknet": "^8.1.10",
    "@atomiqlabs/sdk": "^8.4.3",
    "@bim/atomiq-storage-postgres": "*",
    "@bim/db": "*",
    "@bim/domain": "*",
    "@bim/lib": "*",
    "@bim/starknet": "*",
    "@hono/node-server": "^1.19.9",
    "@noble/curves": "^1.9.7",
    "@stablelib/base64": "^2.0.1",
    "dotenv": "^17.3.1",
    "dotenv-expand": "^12.0.3",
    "hono": "^4.12.3",
    "hono-rate-limiter": "^0.5.3",
    "light-bolt11-decoder": "^3.2.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "starknet": "^9.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@bim/test-toolkit": "*",
    "@testcontainers/postgresql": "^11.12.0",
    "@types/node": "^25.3.3",
    "testcontainers": "^11.12.0"
  }
}
