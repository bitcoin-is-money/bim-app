{
  "name": "@bim/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist public/app",
    "clean:all": "npm run clean && rm -rf node_modules",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --watch --noEmit",
    "dev:testnet": "NETWORK=testnet tsx watch src/main.ts",
    "dev:mainnet": "NETWORK=mainnet tsx watch src/main.ts",
    "build": "npm run typecheck && esbuild src/main.ts --bundle --platform=node --format=esm --outfile=dist/main.js --packages=external",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "test:testnet": "vitest run --config vitest.config.testnet.ts",
    "test:all": "npm run test && npm run test:integration",
    "copy:front": "rm -rf public/app && cp -r ../front/dist/frontend/browser/browser public/app",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts"
  },
  "dependencies": {
    "@atomiqlabs/chain-starknet": "^8.0.13",
    "@atomiqlabs/sdk": "^8.1.8",
    "@atomiqlabs/storage-sqlite": "^5.0.0",
    "@bim/db": "*",
    "@bim/domain": "*",
    "@bim/lib": "*",
    "@hono/node-server": "^1.19.9",
    "@stablelib/base64": "^2.0.1",
    "dotenv": "^17.2.4",
    "dotenv-expand": "^12.0.3",
    "hono": "^4.11.9",
    "light-bolt11-decoder": "^3.2.0",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "starknet": "^9.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@bim/test-toolkit": "*",
    "@testcontainers/postgresql": "^11.11.0",
    "@types/node": "^25.2.2",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.8",
    "testcontainers": "^11.11.0"
  }
}
