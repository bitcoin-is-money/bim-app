{
  "name": "@bim/front",
  "version": "0.0.1",
  "private": true,
  "description": "BIM Angular 21 frontend — Bitcoin wallet UI with WebAuthn passkey authentication.",
  "license": "GPL-3.0-or-later",
  "author": "yannicklacaute@bitcoinismoney.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bitcoin-is-money/bim.git",
    "directory": "apps/front"
  },
  "bugs": {
    "url": "https://github.com/bitcoin-is-money/bim/issues"
  },
  "homepage": "https://github.com/bitcoin-is-money/bim#readme",
  "keywords": [
    "bim",
    "angular",
    "frontend",
    "wallet",
    "webauthn"
  ],
  "scripts": {
    "clean": "rm -rf dist .angular",
    "ng": "ng",
    "start": "ng serve",
    "dev": "ng serve",
    "build:watch": "ng build --watch --configuration development",
    "prebuild:testnet": "tsx scripts/write-build-version.ts",
    "build:testnet": "ng build --configuration testnet",
    "prebuild": "tsx scripts/write-build-version.ts",
    "build": "ng build",
    "test": "ng test --watch=false --coverage",
    "test:watch": "ng test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "dependencies": {
    "@angular/common": "^21.2.9",
    "@angular/compiler": "^21.2.9",
    "@angular/core": "^21.2.9",
    "@angular/forms": "^21.2.9",
    "@angular/platform-browser": "^21.2.9",
    "@angular/router": "^21.2.9",
    "@angular/service-worker": "^21.2.9",
    "@bim/lib": "*",
    "@fortawesome/angular-fontawesome": "^4.0.0",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@stablelib/base64": "^2.0.1",
    "@stablelib/hex": "^2.0.1",
    "canvas-confetti": "^1.9.4",
    "html5-qrcode": "^2.3.8",
    "marked": "^18.0.2",
    "p-timeout": "^7.0.1",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "uqr": "^0.1.3"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.9",
    "@ngneat/overview": "^7.0.0",
    "@ngxpert/hot-toast": "^6.2.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/canvas-confetti": "^1.9.0",
    "autoprefixer": "^10.5.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.2"
  }
}
