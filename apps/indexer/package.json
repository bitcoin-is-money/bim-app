{
  "name": "@bim/indexer",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "BIM Apibara blockchain indexer — watches Starknet for WBTC transfers to user addresses.",
  "license": "GPL-3.0-or-later",
  "author": "yannicklacaute@bitcoinismoney.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bitcoin-is-money/bim.git",
    "directory": "apps/indexer"
  },
  "bugs": {
    "url": "https://github.com/bitcoin-is-money/bim/issues"
  },
  "homepage": "https://github.com/bitcoin-is-money/bim#readme",
  "keywords": [
    "bim",
    "apibara",
    "indexer",
    "starknet",
    "wbtc"
  ],
  "scripts": {
    "clean": "rm -rf .apibara",
    "dev": "dotenv -e .env.testnet.secret -- apibara dev --preset testnet",
    "build": "apibara build && node esbuild.prod.js",
    "start": "dotenv -e .env.mainnet.secret -- apibara start --preset mainnet --indexer wbtc-transfers",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@apibara/indexer": "^2.1.1",
    "@apibara/plugin-drizzle": "^2.1.0-beta.58",
    "@apibara/starknet": "^2.1.1",
    "@bim/db": "*",
    "@bim/domain": "*",
    "@bim/lib": "*",
    "apibara": "^2.1.0-beta.58",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "starknet": "^9.4.2",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "vitest": "^4.1.4"
  }
}
