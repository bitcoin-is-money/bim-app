{
	"$schema": "https://railway.com/railway.schema.json",
	"build": {
		"builder": "DOCKERFILE"
	},
	"deploy": {
		"healthcheckPath": "/api/health-simple",
		"healthcheckTimeout": 300,
		"restartPolicyType": "ON_FAILURE",
		"restartPolicyMaxRetries": 3,
		"memoryLimit": 1024,
		"cpuLimit": 1000
	}
}
