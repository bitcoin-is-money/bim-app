{
	"extends": "./.svelte-kit/tsconfig.json",
	"compilerOptions": {
		// Enhanced type safety options beyond SvelteKit defaults
		"noImplicitAny": true,
		"noImplicitReturns": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"strictNullChecks": true,
		// "exactOptionalPropertyTypes": true, // Disabled: too strict, causes friction with optional properties
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true,
		"resolveJsonModule": true,
		"esModuleInterop": true,
		// Skip type checking for third-party libraries (e.g., Drizzle ORM)
		"skipLibCheck": true,
		// Enable decorator support
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true
	}
}
