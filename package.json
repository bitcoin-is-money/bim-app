{
  "name": "bim",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Bitcoin wallet on Starknet with WebAuthn (passkey/biometric) key management, Lightning Network support, and gasless account deployment via AVNU paymaster.",
  "license": "GPL-3.0-or-later",
  "author": "yannicklacaute@bitcoinismoney.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bitcoin-is-money/bim.git"
  },
  "bugs": {
    "url": "https://github.com/bitcoin-is-money/bim/issues"
  },
  "homepage": "https://github.com/bitcoin-is-money/bim#readme",
  "keywords": [
    "bitcoin",
    "starknet",
    "lightning",
    "webauthn",
    "passkey",
    "wallet",
    "atomiq",
    "avnu",
    "paymaster"
  ],
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "clean": "npm run clean --workspaces --if-present",
    "clean:all": "npm run clean && rm -rf node_modules packages/*/node_modules apps/*/node_modules package-lock.json",
    "build:libs": "npm run build -w @bim/test-toolkit && npm run build -w @bim/lib && npm run build -w @bim/domain && npm run build -w @bim/db && npm run build -w @bim/atomiq-storage-postgres && npm run build -w @bim/starknet && npm run build -w @bim/atomiq && npm run build -w @bim/slack",
    "build:front": "npm run build -w @bim/front",
    "build:api": "npm run build:libs && npm run build -w @bim/api && npm run build:front && npm run copy:front -w @bim/api",
    "build:indexer": "npm run build:libs && npm run build -w @bim/indexer",
    "build": "npm run build:api && npm run build:indexer",
    "dev": "npm run dev -w @bim/api",
    "dev:front": "npm run dev -w front",
    "test": "npm run test -w @bim/test-toolkit && npm run test -w @bim/lib && npm run test -w @bim/domain && npm run test -w @bim/atomiq-storage-postgres && npm run test -w @bim/indexer && npm run test -w @bim/api && npm run test -w @bim/front",
    "test:integration": "npm run test:integration -w @bim/api",
    "test:e2e": "npm run test:e2e -w @bim/api",
    "test:e2e:deploy": "npm run test:e2e:deploy -w @bim/api",
    "test:e2e:starknet": "npm run test:e2e:starknet -w @bim/api",
    "test:e2e:lightning": "npm run test:e2e:lightning -w @bim/api",
    "test:e2e:bitcoin": "npm run test:e2e:bitcoin -w @bim/api",
    "db:up": "docker compose up -d postgres && until docker compose exec postgres pg_isready -U bim_user -d bim > /dev/null 2>&1; do sleep 1; done && DATABASE_URL=postgresql://bim_user:bim_password@localhost:${DB_PORT:-5432}/bim npm run db:push",
    "db:push": "npm run db:push -w @bim/db",
    "db:generate": "npm run db:generate -w @bim/db",
    "db:migrate": "npm run db:migrate -w @bim/db",
    "db:studio": "npm run db:studio -w @bim/db",
    "docker:build": "./scripts/docker.sh build",
    "docker:push": "./scripts/docker.sh push",
    "docker:up": "./scripts/docker.sh up",
    "docker:down": "./scripts/docker.sh down",
    "docker:logs": "./scripts/docker.sh logs",
    "docker:ship": "./scripts/docker.sh ship",
    "docker:ship:api": "./scripts/docker.sh ship api",
    "docker:ship:indexer": "./scripts/docker.sh ship indexer",
    "docker:redeploy": "./scripts/docker.sh redeploy",
    "docker:force-redeploy": "./scripts/docker.sh force-redeploy",
    "infra:plan": "./scripts/docker.sh plan",
    "infra:apply": "./scripts/docker.sh apply",
    "infra:init": "./scripts/docker.sh init",
    "security": "npm run security:audit; npm run security:lockfile",
    "security:audit": "better-npm-audit audit --level moderate",
    "security:lockfile": "lockfile-lint --path package-lock.json --type npm --allowed-hosts npm --validate-https",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "deps:check": "npx npm-check-updates --workspaces --root",
    "deps:update": "npx npm-check-updates --workspaces --root -u && npm install"
  },
  "engines": {
    "node": ">=22.22.2 <23"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@secretlint/secretlint-rule-preset-recommend": "^12.1.0",
    "@vitest/coverage-v8": "^4.1.4",
    "angular-eslint": "^21.3.1",
    "better-npm-audit": "^3.11.0",
    "dotenv-cli": "^11.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-security": "^4.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "lockfile-lint": "^5.0.0",
    "patch-package": "^8.0.1",
    "secretlint": "^12.3.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@atomiqlabs/base": "^13.2.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": "eslint --fix --max-warnings=0 --no-warn-ignored",
    "apps/front/src/**/*.html": "eslint --fix --max-warnings=0 --no-warn-ignored",
    "*": "secretlint --maskSecrets"
  },
  "commitlint": {
    "extends": ["@commitlint/config-conventional"]
  },
  "secretlint": {
    "rules": [
      {
        "id": "@secretlint/secretlint-rule-preset-recommend",
        "rules": [
          {
            "id": "@secretlint/secretlint-rule-database-connection-string",
            "options": { "allows": ["/bim_user:bim_password/"] }
          }
        ]
      }
    ]
  }
}
